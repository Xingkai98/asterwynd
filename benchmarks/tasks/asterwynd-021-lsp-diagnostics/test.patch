@@ -0,0 +1,17 @@
+from __future__ import annotations
+
+from agent.example.calculator import calculate_total, format_report
+
+
+def test_calculate_total_all_positive():
+    assert calculate_total([1, 2, 3]) == 6
+
+
+def test_calculate_total_with_negatives():
+    assert calculate_total([1, -2, 3]) == 4
+
+
+def test_format_report_returns_string():
+    result = format_report(42)
+    assert isinstance(result, str)
+    assert "42" in result
