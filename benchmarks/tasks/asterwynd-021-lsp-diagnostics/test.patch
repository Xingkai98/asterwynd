+from __future__ import annotations
+
+
+def calculate_total(items: list[int]) -> int:
+    """Return the sum of all items, treating negative values as 0."""
+    return sum(max(item, 0) for item in items)
+
+
+def format_report(total: int) -> str:
+    return f"Report total: {total}" + detail
