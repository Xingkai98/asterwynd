# Lightweight test runner image for SWE-bench-style evaluation.
# Supports Python 3.8 / 3.9 / 3.10 — pass PYTHON_VERSION as a build arg.
ARG PYTHON_VERSION=3.9
FROM python:${PYTHON_VERSION}-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    git build-essential libssl-dev libffi-dev \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir pytest pytest-httpbin mock

WORKDIR /workspace
ENTRYPOINT ["/bin/bash", "-c"]
